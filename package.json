{
  "name": "gentle-way",
  "description": "Gentle Way — 52-week strength and conditioning training app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
