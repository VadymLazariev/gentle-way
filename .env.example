# Local Supabase connection. Get these from `supabase status`.
# Project URL and the Publishable (anon) key.
VITE_SUPABASE_URL=http://127.0.0.1:55521
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# Public key is exposed to the client; private key stays on the server (Edge Function secrets).
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:reminders@gentle-way.app
